# Database
DB_HOST=127.0.0.1
DB_PORT=5435
DB_NAME=roles
DB_USER=roles_app
DB_PASS=your_secure_password_here

# S3 Object Storage (for CSV downloads and pipeline)
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_REGION=eu-central-1
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=siipredios

# HERE Geocoding API (https://developer.here.com)
HERE_API_KEY=your_here_api_key

# Stats endpoint token
STATS_TOKEN=your_stats_token

# Frontend URL (for CORS)
FRONTEND_URL=https://roles.tremen.tech

# API port
API_PORT=3009
